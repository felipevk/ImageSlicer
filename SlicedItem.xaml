<UserControl x:Class="ImageSlicer.SlicedItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ImageSlicer"
             mc:Ignorable="d" 
             d:DesignHeight="250" d:DesignWidth="320" Width="320">
    <Grid Width="320" Height="250">
        <StackPanel>
            <TextBox x:Name="text" Text="[index]" IsEnabled="False" />
            <Image x:Name="sliceImage" Source="/paris.jpg" Height="207" Width="268" />
        </StackPanel>
    </Grid>
</UserControl>
