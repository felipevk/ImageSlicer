<Window x:Class="ImageSlicer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ImageSlicer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Canvas x:Name="mainCanvas" MouseLeftButtonDown="mainCanvas_MouseLeftButtonDown" Margin="0,61,0,0"/>
        <Button x:Name="sliceButton" Content="Slice" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Width="142" Height="38" FontSize="16" FontWeight="Bold"/>
    </Grid>
</Window>
